{
  "name": "eternal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "programs/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev-setup.ts",
    "dev:local": "bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "dev:web:local": "cd apps/web && NEXT_PUBLIC_SOLANA_CLUSTER=localnet NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899 bun run dev",
    "demo:local": "bun run dev",
    "build": "cd apps/web && bun run build",
    "lint": "cd apps/web && bun run lint",
    "check": "cd apps/web && bun run check",
    "test": "bun run test:program",
    "test:program": "cd programs/asset-tokenization && bun run test"
  }
}
